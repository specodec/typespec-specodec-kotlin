{
  "name": "@specodec/typespec-emitter-kotlin",
  "version": "1.0.6",
  "type": "module",
  "main": "dist/index.js",
  "typespec": {
    "emitter": true,
    "options": {
      "@specodec/typespec-emitter-kotlin": {
        "type": "object",
        "properties": {
          "emitter-output-dir": {
            "type": "string"
          },
          "ignore-reserved-keywords": {
            "type": "boolean"
          }
        },
        "required": [
          "emitter-output-dir"
        ]
      }
    }
  },
  "scripts": { "test": "vitest run",
    "build": "tsc",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@specodec/typespec-emitter-core": "^1.0.0",
    "@typespec/compiler": "^1.12.0",
    "@typespec/http": "^1.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "registry": "http://10.199.64.20:30000/api/packages/specodec/npm/"
  },
  "peerDependencies": {
    "@specodec/typespec-emitter-core": "^1.0.0",
    "@typespec/compiler": "^1.12.0"
  }
}
